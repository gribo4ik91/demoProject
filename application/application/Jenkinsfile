pipeline {
    agent any

    environment {
        APP_DIR = 'application/application'
        APP_COMPOSE_FILE = 'docker-compose.app.yml'
    }

    parameters {
        choice(
            name: 'ACTION',
            choices: ['full', 'build', 'test', 'jar', 'image', 'up', 'down', 'restart', 'logs', 'ps'],
            description: 'Select what application-build should do'
        )
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Application Control') {
            steps {
                dir("${APP_DIR}") {
                    script {
                        def action = params.ACTION ?: 'full'

                        if (isUnix()) {
                            switch (action) {
                                case 'build':
                                    sh 'chmod +x gradlew'
                                    sh './gradlew clean build -x test'
                                    break
                                case 'test':
                                    sh 'chmod +x gradlew'
                                    sh './gradlew test'
                                    break
                                case 'jar':
                                    sh 'chmod +x gradlew'
                                    sh './gradlew clean bootJar'
                                    break
                                case 'image':
                                    sh "docker compose -f ${APP_COMPOSE_FILE} build"
                                    break
                                case 'up':
                                    sh "docker compose -f ${APP_COMPOSE_FILE} up -d"
                                    break
                                case 'down':
                                    sh "docker compose -f ${APP_COMPOSE_FILE} down"
                                    break
                                case 'restart':
                                    sh "docker compose -f ${APP_COMPOSE_FILE} down"
                                    sh "docker compose -f ${APP_COMPOSE_FILE} up -d"
                                    break
                                case 'logs':
                                    sh "docker compose -f ${APP_COMPOSE_FILE} logs --tail=200 --no-color"
                                    break
                                case 'ps':
                                    sh "docker compose -f ${APP_COMPOSE_FILE} ps"
                                    break
                                case 'full':
                                    sh 'chmod +x gradlew'
                                    sh './gradlew clean test bootJar'
                                    sh "docker compose -f ${APP_COMPOSE_FILE} build"
                                    sh "docker compose -f ${APP_COMPOSE_FILE} up -d"
                                    break
                                default:
                                    error "Unsupported ACTION: ${action}"
                            }
                        } else {
                            switch (action) {
                                case 'build':
                                    bat '.\\gradlew.bat clean build -x test'
                                    break
                                case 'test':
                                    bat '.\\gradlew.bat test'
                                    break
                                case 'jar':
                                    bat '.\\gradlew.bat clean bootJar'
                                    break
                                case 'image':
                                    bat "docker compose -f ${APP_COMPOSE_FILE} build"
                                    break
                                case 'up':
                                    bat "docker compose -f ${APP_COMPOSE_FILE} up -d"
                                    break
                                case 'down':
                                    bat "docker compose -f ${APP_COMPOSE_FILE} down"
                                    break
                                case 'restart':
                                    bat "docker compose -f ${APP_COMPOSE_FILE} down"
                                    bat "docker compose -f ${APP_COMPOSE_FILE} up -d"
                                    break
                                case 'logs':
                                    bat "docker compose -f ${APP_COMPOSE_FILE} logs --tail=200 --no-color"
                                    break
                                case 'ps':
                                    bat "docker compose -f ${APP_COMPOSE_FILE} ps"
                                    break
                                case 'full':
                                    bat '.\\gradlew.bat clean test bootJar'
                                    bat "docker compose -f ${APP_COMPOSE_FILE} build"
                                    bat "docker compose -f ${APP_COMPOSE_FILE} up -d"
                                    break
                                default:
                                    error "Unsupported ACTION: ${action}"
                            }
                        }
                    }
                }
            }
        }

        stage('Smoke Test') {
            when {
                expression { params.ACTION == 'full' }
            }
            steps {
                script {
                    if (isUnix()) {
                        sh '''
                            for i in 1 2 3 4 5; do
                              if curl --fail --silent http://localhost:8085/api-docs > /dev/null; then
                                exit 0
                              fi
                              sleep 5
                            done
                            exit 1
                        '''
                    } else {
                        powershell '''
                            $attempts = 5
                            for ($i = 0; $i -lt $attempts; $i++) {
                                try {
                                    Invoke-WebRequest -UseBasicParsing http://localhost:8085/api-docs -TimeoutSec 10 | Out-Null
                                    exit 0
                                } catch {
                                    Start-Sleep -Seconds 5
                                }
                            }
                            exit 1
                        '''
                    }
                }
            }
        }
    }

    post {
        always {
            junit testResults: 'application/application/build/test-results/test/*.xml', allowEmptyResults: true
        }
        success {
            echo "Application job finished successfully. ACTION=${params.ACTION}"
        }
        failure {
            echo "Application job failed. ACTION=${params.ACTION}. Check build, container, or smoke test logs."
        }
    }
}
